# Atalaya — example environment. Copy to .env (gitignored) and fill. NO secrets are committed here.
# Secrets live in the private CAOS management vault and are materialized into .env by scripts/setup.*.
#
# The default pipeline (processing already-mirrored data + the committed catalog) needs NONE of these.
# They only matter when you RE-HARVEST the live catalog or relocate the heavy data/model scratch.

# --- Data Observatory catalog backend (read-only; only needed to re-crawl the catalog) ---------------------
# Unofficial endpoint extracted from the public catalog SPA; see docs/frameworks/opensearch-catalog/.
ATALAYA_DO_API_BASE=https://d2i4qx9nxxjzd9.cloudfront.net/prod-v3
ATALAYA_DO_API_USER=front-reader
ATALAYA_DO_API_PASS=                      # read-only credential; provided by the vault, never committed

# --- heavy data + models scratch (OUTSIDE git) — override per machine -------------------------------------
ATALAYA_DATA_ROOT=E:\_Datos\atalaya       # raw mirror + normalized parquet + graph.db + catalog cache
ATALAYA_MODEL_ROOT=E:\_Models\atalaya     # trained sklearn bundle + exported ONNX encoder

# --- harvest budget guardrails ----------------------------------------------------------------------------
ATALAYA_DISK_CAP_GB=400                    # hard cap on the raw mirror
ATALAYA_MONSTER_GB=50                      # a single resource above this is subset, never mirrored
ATALAYA_MAX_CONCURRENCY_PER_HOST=3        # be polite to small gov file hosts

# --- embedding model (fully local; exported to ONNX for the browser live lane) ----------------------------
ATALAYA_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- dormant app/ backend (only if the ADR-0002 trigger ever applies) -------------------------------------
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000
DEV_ORIGINS=http://localhost:5173
FRONTEND_DIST=frontend/dist
DATA_DIR=data/derived
